OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4o-mini
# Optional: use a compatible API (Azure, local proxy, Groq, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# Groq example (most models need json_object, not json_schema — auto handles this):
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
#
# Structured output mode: auto | strict | off
# - auto: json_schema on OpenAI; json_object on unsupported Groq models
# - strict: always json_schema (fails on Groq Llama/Mixtral)
# - off: always json_object
# OPENAI_JSON_SCHEMA=auto
